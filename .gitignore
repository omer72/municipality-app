# OS
.DS_Store

# Dependencies
app/node_modules/

# Build output
app/dist/

# Per-city generated artifacts (regenerated by scripts/build-city.mjs)
app/capacitor.config.json
app/public/config.json
app/public/logo.png
app/public/sprite.svg
app/assets/icon-only.png
app/assets/splash.png

# iOS bundle copies (cap sync overwrites on every build)
app/ios/App/App/public/
app/ios/App/App/capacitor.config.json

# Xcode user data
app/ios/App/App.xcodeproj/xcuserdata/
app/ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
app/ios/DerivedData/

# Claude local settings
.claude/settings.local.json
